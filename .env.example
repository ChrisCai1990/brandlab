# MongoDB connection string (required)
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/brandlab"

# JWT signing secret — use a random 32+ character string (required)
NEXTAUTH_SECRET="your-random-secret-here"

# Initial admin password — can be removed after changing password in /admin/settings
ADMIN_PASSWORD="your-admin-password"

# Gemini API Key — for HTML Content Generator tool
# Get free key at: https://aistudio.google.com
GEMINI_API_KEY="your-gemini-api-key-here"
